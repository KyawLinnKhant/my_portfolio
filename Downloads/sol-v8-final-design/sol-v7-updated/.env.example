# Spotify API Configuration
# Get these from: https://developer.spotify.com/dashboard
# Required for song search to work

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: Only needed for user authentication flow (not currently used)
SPOTIFY_REDIRECT_URI=https://your-domain.vercel.app/api/spotify/callback

# Note: Client ID and Secret are REQUIRED for search to work
# Without these, Spotify search will return empty results
